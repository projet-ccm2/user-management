# Environment Configuration
NODE_ENV=development
PORT=3000

# Twitch API Configuration
# Get your Client ID from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_ISSUER=https://id.twitch.tv/oauth2

# CORS Configuration
# List of allowed domains separated by commas
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# Database Service Configuration
# Database service URL
DB_SERVICE_URL=http://localhost:3001

# VPC Token Configuration (for bastion access to db gateway)
# URL of user-management for POST /tokens (auto-call and second BFF)
USER_MANAGEMENT_URL=http://localhost:3000
# Secret to sign JWT for VPC access (required in production)
JWT_SECRET=dev-secret-change-in-production